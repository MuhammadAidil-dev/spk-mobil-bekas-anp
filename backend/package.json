{
  "name": "spk-mobil-bekas-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "build": "npm run clean && tsc --project tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "seed:admin": "tsx src/seeders/admin.seed.ts seed",
    "seed:admin:clear": "tsx src/seeders/admin.seed.ts clear",
    "seed:car": "tsx src/seeders/cars.seed.ts seed",
    "seed:car:clear": "tsx src/seeders/cars.seed.ts clear",
    "seed:new-car": "tsx src/seeders/newCars.seed.ts seed",
    "seed:new-car:clear": "tsx src/seeders/newCars.seed.ts clear",
    "seed:criteria": "tsx src/seeders/criteria.seed.ts seed",
    "seed:criteria:clear": "tsx src/seeders/criteria.seed.ts clear"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "sistem pendukung keputusan mobil bekas menggunakan metode ANP",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.4.0",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
